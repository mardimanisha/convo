{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir":           "./dist",
    "rootDir":          "./src",
    "module":           "ESNext",
    "moduleResolution": "Bundler",
    "jsx":              "react-jsx",
    "lib":              ["ES2022", "DOM", "DOM.Iterable"],
    "types":            ["jest", "@testing-library/jest-dom", "node"],
    "baseUrl":          ".",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["node_modules", "dist"]
}
